{
  "name": "softuq",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.28.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "start": "pnpm --filter @softuq/docs start",
    "dev": "pnpm --filter @softuq/docs dev",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "format": "biome format --write .",
    "publish:cli": "set -a && . ./.env && set +a && pnpm --filter softuq publish --//registry.npmjs.org/:_authToken=$NPM_TOKEN --no-git-checks"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "typescript": "^6.0.2"
  }
}
