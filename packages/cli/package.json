{
  "name": "softuq",
  "version": "0.8.0",
  "description": "CLI for Softuq — add UI components and the design skill to your project",
  "type": "module",
  "license": "MIT",
  "homepage": "https://softuq.com",
  "keywords": [
    "softuq",
    "design-system",
    "cli",
    "components",
    "react",
    "tailwind",
    "ui",
    "soft-ui",
    "claude-code",
    "skill",
    "ai"
  ],
  "bin": {
    "softuq": "dist/index.js"
  },
  "files": [
    "dist",
    "templates",
    "skill",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "sync": "node scripts/sync-templates.mjs",
    "prebuild": "pnpm sync",
    "build": "tsup src/index.ts --format esm",
    "dev": "tsup src/index.ts --format esm --watch",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "fs-extra": "^11.3.4",
    "picocolors": "^1.1.1",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/prompts": "^2.4.9",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2"
  }
}
